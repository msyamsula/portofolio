# Copy to .env before running: cp env.example .env
# These values are used directly by the api and worker containers via env_file.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=message
DATABASE_URL=postgres://postgres:postgres@postgres/message?sslmode=disable

# DB_DSN is what the Go service reads for pgxpool connection.
DB_DSN=postgres://postgres:postgres@postgres/message?sslmode=disable

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=message.events

# Outbox relay (runs in API process): how many events to batch per tick.
OUTBOX_BATCH=100

# Reconciler (runs in Worker process): how often to sweep for stuck messages.
RECONCILE_INTERVAL=1m

# Retry/attempt budgets:
#   MAX_RETRY:   RECONCILE_STUCKED_MESSAGE events before escalating to RECONCILE_FAILED.
#   MAX_ATTEMPT: RECONCILE_FAILED_MESSAGE  events before writing terminal FAILED.
MAX_RETRY=3
MAX_ATTEMPT=3

# HTTP server port (inside container; docker-compose maps this to API_PORT on host).
PORT=:8080
API_PORT=8080
