# Google OAuth 2.0 credentials (required)
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic API key for Claude CLI (required)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Path to the Claude CLI binary (optional, defaults to "claude")
CLAUDE_PATH=claude

# Public base URL used for OAuth redirect URI (optional, defaults to http://localhost:8080)
BASE_URL=https://calendar-ai-jpz3.onrender.com

# Server host and port (optional)
HOST=0.0.0.0
PORT=8080
